rune x = 10

spell square(n):
    unleash n * n

spell greet(name):
    cast("Hello, " + name)

ritual main():
    greet("RuneForge")

    rune result = square(x)
    cast(str(result))

    when x > 5:
        cast("x is big")
    orwhen x == 5:
        cast("x is five")
    otherwise:
        cast("x is small")

    rune i = 0
    while i < 3:
        cast(str(i))
        i = i + 1
